generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Species {
  id             String   @id @default(uuid())
  commonName     String
  scientificName String
  category       String
  latitude       Float
  longitude      Float
  externalData   Json?
  createdAt      DateTime @default(now())
}
